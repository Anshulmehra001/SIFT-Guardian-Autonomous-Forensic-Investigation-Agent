# SIFT Guardian Configuration Template
# Copy this file to config.yaml and add your API key

ai:
  provider: "gemini"
  api_key: "your-api-key-here"  # Get from https://ai.google.dev/
  model: "models/gemini-2.5-flash"
  temperature: 0.1
  max_tokens: 4096
  timeout: 60

security:
  evidence_readonly: true
  require_hash_verification: true
  command_whitelist_enabled: true

self_correction:
  enabled: true
  confidence_threshold: 0.75
  max_iterations: 3

audit:
  enabled: true
  log_directory: "./audit_logs"
  hash_algorithm: "sha256"

reporting:
  output_directory: "./reports"
  formats:
    - markdown
    - json
